[Unit]
Description=Host Monitor Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/hostmonitor
ExecStart=/opt/hostmonitor/hostmonitor
Restart=always
RestartSec=5s

# Configuration
Environment=HOSTMONITOR_CONFIG=/opt/hostmonitor/hostmonitor.yaml

# Logging to journald
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
